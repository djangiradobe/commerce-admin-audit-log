{
  "name": "@adobedjangir/commerce-admin-audit-log",
  "version": "1.0.7",
  "description": "Audit log + revert add-on for @adobedjangir/commerce-admin-management. Records every system_config change with old/new/actor and exposes a UI tab to inspect + revert.",
  "license": "Apache-2.0",
  "author": "Adobe Inc.",
  "keywords": [
    "adobe-io",
    "aio",
    "app-builder",
    "commerce-admin",
    "audit-log"
  ],
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./hook": "./src/hook.js",
    "./web": "./web/index.js"
  },
  "scripts": {
    "build": "node ./scripts/build-web.js",
    "prepublishOnly": "node ./scripts/build-web.js",
    "postinstall": "node ./scripts/setup.js && node -e \"try{require('@adobedjangir/commerce-admin-management/scripts/discover').run()}catch(e){}\""
  },
  "files": [
    "src",
    "actions",
    "web",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "@adobedjangir/commerce-admin-management": ">=1.0.0",
    "@adobedjangir/commerce-admin-get-config": ">=1.0.0"
  },
  "commerceAdmin": {
    "register": "registerAuditLog"
  }
}
